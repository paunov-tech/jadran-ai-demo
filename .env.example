# JADRAN.AI — Required Environment Variables
# Copy to .env.local for dev, set in Vercel for production.

# ═══ REQUIRED ═══

# AI (Anthropic Claude) — chat + pulse
ANTHROPIC_API_KEY=sk-ant-...

# Maps (HERE) — routing, traffic, geocoding, nearby
HERE_API_KEY=...
VITE_HERE_API_KEY=...

# Database (Firebase Firestore)
FIREBASE_API_KEY=...
VITE_FB_API_KEY=...
VITE_FB_AUTH_DOMAIN=molty-portal.firebaseapp.com
VITE_FB_PROJECT_ID=molty-portal
VITE_FB_STORAGE=molty-portal.firebasestorage.app
VITE_FB_MSG_ID=...
VITE_FB_APP_ID=...

# Payments (Stripe LIVE)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ═══ OPTIONAL ═══

# Gemini — kiosk live info, vision
GEMINI_API_KEY=...

# Email (Resend)
RESEND_API_KEY=re_...

# Push notifications
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:info@sialconsulting.com
